{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    // Dev-only: targets the local docker-compose SQL Server (see docker-compose.yml
    // at repo root). Production connection strings come from Key Vault, never config files.
    "GroceryCompare": "Server=localhost,14330;Database=GroceryCompare;User Id=sa;Password=LocalDev!Passw0rd;TrustServerCertificate=True"
  },
  "Jwt": {
    // Dev-only signing key; production uses Key Vault.
    "SigningKey": "dev-only-signing-key-grocerycompare-0123456789abcdef"
  },
  "GoogleAuth": {
    // Fill with your OAuth 2.0 Web client ID (or use `dotnet user-secrets set
    // GoogleAuth:ClientId <id>`); must match VITE_GOOGLE_CLIENT_ID in the SPA.
    "ClientId": ""
  }
}
