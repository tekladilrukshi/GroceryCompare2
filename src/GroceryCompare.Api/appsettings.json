{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "GroceryCompare.Api",
    "Audience": "GroceryCompare.Web",
    // Set per environment: dev value in appsettings.Development.json,
    // production from Key Vault. Startup fails fast if left empty.
    "SigningKey": "",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 30
  },
  "GoogleAuth": {
    // OAuth 2.0 Web client ID from Google Cloud Console; must match the
    // SPA's VITE_GOOGLE_CLIENT_ID.
    "ClientId": ""
  }
}
